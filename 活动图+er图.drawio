        </mxCell>
        <mxCell id="lane_div2" value="" style="endArrow=none;html=1;strokeColor=#000000;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="70" as="sourcePoint" />
            <mxPoint x="780" y="1330" as="targetPoint" />
